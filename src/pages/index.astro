---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { site } from "../data/site";

const page = await getEntry("pages", "home");
if (!page) throw new Error("Missing home content");
const { Content } = await page.render();
const canonicalUrl = new URL(page.data.canonicalPath, site.domain).toString();
const faq = page.data.faq ?? [];
const faqSchema = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
} : null;

const fundingCategories = [
  { href: "/contractor-working-capital", title: "Contractor Working Capital", desc: "Payroll, material deposits, and short-term cash flow support.", img: "https://images.unsplash.com/photo-1759922378222-47ad736a174d?w=400&q=80" },
  { href: "/construction-equipment-financing", title: "Equipment Financing", desc: "Finance excavators, skid steers, trucks, trailers, and more.", img: "https://images.unsplash.com/photo-1756388812709-3d524bc42b9b?w=400&q=80" },
  { href: "/contractor-line-of-credit", title: "Contractor Line of Credit", desc: "Flexible capital for recurring timing gaps.", img: "https://images.unsplash.com/photo-1752751788742-e79cac56ba4f?w=400&q=80" },
  { href: "/construction-business-loans", title: "Construction Business Loans", desc: "Term loans for expansion, acquisition, and larger projects.", img: "https://images.unsplash.com/photo-1749467140438-feda1a2bbbd8?w=400&q=80" }
];
---
<BaseLayout title={page.data.title} description={page.data.description} canonicalUrl={canonicalUrl} ogType="website">
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}

  <section class="hero-banner">
    <div class="hero-bg" aria-hidden="true">
      <img src="https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=1600&q=85" alt="" role="presentation" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <h1>Contractor Cash Flow: Why the Timing Gap Happens</h1>
      <p>Construction businesses face a timing mismatch: labor is paid weekly, materials are due before milestones, and equipment costs hit before client payments arrive. Net-60 and net-90 terms are common. This guide explains the problems and the funding options contractors sometimes use to bridge the gap.</p>
      <a class="btn" href={site.ctaUrl} rel="sponsored noopener noreferrer" target="_blank">{site.ctaText}</a>
    </div>
  </section>

  <section class="container home-grid">
    <div class="funding-categories">
      <h2>Funding Options</h2>
      <div class="grid grid-4">
        {fundingCategories.map((c) => (
          <div class="card card-img">
            <div class="card-image">
              <img src={c.img} alt="" loading="lazy" />
            </div>
            <div class="card-body">
              <strong>{c.title}</strong>
              <p>{c.desc}</p>
              <a class="btn-link" href={c.href}>View guide</a>
            </div>
          </div>
        ))}
      </div>
    </div>
    <aside class="sidebar">
      <div class="trust-pills">
        <h3>Common situations</h3>
        <span>Payroll gaps</span>
        <span>Waiting on invoices</span>
        <span>Equipment costs</span>
        <span>Material timing</span>
        <span>Project start costs</span>
      </div>
      <div class="explore-links">
        <h3>More Guides</h3>
        <a class="btn-link" href="/contractor-cash-flow-problems">Cash Flow Problems</a>
        <a class="btn-link" href="/contractor-payroll-funding">Payroll Funding</a>
        <a class="btn-link" href="/contractor-material-purchase-financing">Material Financing</a>
        <a class="btn-link" href="/accounts-receivable-financing-contractors">Receivables</a>
        <a class="btn-link" href="/faq">FAQ</a>
        <a class="btn-link" href="/blog">Blog</a>
      </div>
    </aside>
  </section>

  <article class="container prose">
    <Content />
    <div class="cta">
      <h2>{page.data.ctaTitle}</h2>
      <p>{page.data.ctaText}</p>
      <a class="btn" href={site.ctaUrl} rel="sponsored noopener noreferrer" target="_blank">{site.ctaText}</a>
    </div>
  </article>

  <style>
    .hero-banner { position: relative; min-height: 280px; display: flex; align-items: center; width: 100%; }
    .hero-bg { position: absolute; inset: 0; }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(43,43,43,.9) 0%, rgba(43,43,43,.6) 50%, transparent 100%); pointer-events: none; }
    .hero-bg { pointer-events: none; }
    .hero-content { position: relative; z-index: 1; color: #fff; padding: 40px 20px; width: 100%; max-width: 100%; box-sizing: border-box; }
    .hero-content h1 { font-family: 'Oswald', sans-serif; color: #fff; margin-bottom: 10px; font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; max-width: 100%; overflow-wrap: break-word; }
    .hero-content p { color: #e5e7eb; max-width: 480px; margin-bottom: 16px; font-size: 0.95rem; overflow-wrap: break-word; }
    .hero-content .btn { background: var(--cta); color: #fff !important; }
    .home-grid { display: grid; grid-template-columns: 1fr 220px; gap: 32px; margin-top: 24px; align-items: start; }
    @media (max-width: 768px) { .home-grid { grid-template-columns: 1fr; } }
    .funding-categories h2 { font-family: 'Oswald', sans-serif; font-size: 1.35rem; margin: 0 0 16px 0; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; color: var(--charcoal); }
    .grid-4 { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    @media (min-width: 600px) { .grid-4 { grid-template-columns: repeat(4, 1fr); } }
    .sidebar { display: flex; flex-direction: column; gap: 20px; }
    .trust-pills { display: flex; flex-direction: column; gap: 8px; }
    .trust-pills h3 { font-family: 'Oswald', sans-serif; font-size: 0.9rem; margin: 0 0 4px 0; font-weight: 600; color: var(--concrete); text-transform: uppercase; letter-spacing: 0.08em; }
    .trust-pills span { display: inline-block; width: fit-content; }
    .trust-pills span { font-size: 0.8rem; padding: 6px 12px; background: var(--surface); border: 1px solid var(--border); border-radius: 4px; color: var(--concrete); }
    .explore-links { display: flex; flex-direction: column; gap: 8px; }
    .explore-links h3 { font-family: 'Oswald', sans-serif; font-size: 0.9rem; margin: 0 0 8px 0; font-weight: 600; color: var(--concrete); text-transform: uppercase; letter-spacing: 0.08em; }
    .explore-links .btn-link { width: 100%; text-align: center; }
  </style>
</BaseLayout>
