---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, getCollection } from "astro:content";
import { site } from "../data/site";
import { breadcrumbSchema } from "../utils/breadcrumbs";

const page = await getEntry("pages", "home");
if (!page) throw new Error("Missing home content");
const canonicalUrl = new URL(page.data.canonicalPath, site.domain).toString();
const faq = page.data.faq ?? [];
const faqSchema = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
} : null;

const allPosts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latestPosts = allPosts.slice(0, 6);

const cashFlowProblems = [
  { title: "Payroll gaps", desc: "Labor must be paid weekly or biweekly, but project draws may not arrive for 30–90 days.", href: "/how-contractors-pay-workers-before-invoices-clear", icon: "payroll" },
  { title: "Waiting on invoices", desc: "Work is done and invoices sent, but payment can take 60–90 days or more.", href: "/what-contractors-do-when-invoices-delayed", icon: "invoice" },
  { title: "Material deposits", desc: "Suppliers want payment before or upon delivery; clients pay after milestones.", href: "/how-contractors-buy-materials-before-getting-paid", icon: "materials" },
  { title: "Equipment breakdown costs", desc: "Unexpected repairs or replacements can drain reserves and stall jobs.", href: "/contractor-equipment-breakdown-funding", icon: "equipment" },
  { title: "Project startup costs", desc: "Mobilization, materials, and labor hit before the first payment arrives.", href: "/how-contractors-start-jobs-before-payment", icon: "startup" }
];

const paymentCycleSteps = [
  "Project Starts",
  "Contractor Buys Materials",
  "Labor Paid Weekly",
  "Work Completed",
  "Invoice Sent",
  "Client Pays 30–90 Days Later"
];

const fundingOptions = [
  { href: "/contractor-working-capital", title: "Contractor Working Capital", desc: "Short-term funding for payroll, materials, and operating gaps when client payments are delayed." },
  { href: "/construction-equipment-financing", title: "Construction Equipment Financing", desc: "Finance excavators, skid steers, trucks, and machinery. The equipment secures the financing." },
  { href: "/contractor-line-of-credit", title: "Contractor Line of Credit", desc: "Revolving access for recurring timing gaps. Draw when needed, repay when cash arrives." },
  { href: "/construction-business-loans", title: "Construction Business Loans", desc: "Term loans for expansion, acquisition, and larger projects." },
  { href: "/contractor-payroll-funding", title: "Contractor Payroll Funding", desc: "Bridge payroll when draws or invoices are delayed." }
];

const trustPoints = [
  "Clear explanations in plain language",
  "Guides built around real contractor cash-flow problems",
  "Practical comparisons of different financing options",
  "Educational resource first, sales pitch second"
];

const breadcrumbItems = [{ name: "Home", url: "/" }];
const breadcrumbSchemaJson = breadcrumbSchema(breadcrumbItems, new URL("/", site.domain).toString());
---
<BaseLayout title={page.data.title} description={page.data.description} canonicalUrl={canonicalUrl} ogType="website">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchemaJson)} slot="head" />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: page.data.title,
    description: page.data.description,
    url: canonicalUrl,
    abstract: page.data.quickAnswer
  })} slot="head" />

  <!-- 1. Hero Section -->
  <section class="hero-banner">
    <div class="hero-bg" aria-hidden="true">
      <img src="https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=1600&q=85" alt="" role="presentation" loading="eager" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <p class="hero-eyebrow">Contractor Cash Flow Guide</p>
      <h1>Why the Timing Gap Happens—and What Contractors Do About It</h1>
      <p class="hero-subheading">Labor is paid weekly. Materials are paid upfront. Client invoices often pay 30–90 days later. Construction businesses face this timing mismatch every day.</p>
      <p class="hero-desc">This guide explains the cash flow problems contractors face and the funding options many use to bridge the gap between when money goes out and when it comes in.</p>
      <div class="hero-cta">
        <a class="btn btn-hero" href="/contractor-cash-flow-problems">Understand contractor cash flow</a>
        <a class="hero-link-secondary" href="/contractor-cash-flow-problems">See the most common contractor cash flow problems</a>
      </div>
    </div>
  </section>

  <!-- 2. Quick Answer + Definition -->
  <section class="section section-quick">
    <div class="container container-narrow">
      <p class="section-eyebrow">Quick answer</p>
      <div class="quick-answer" role="complementary" aria-label="Quick answer">
        <p>{page.data.quickAnswer}</p>
      </div>
      <div class="definition-block">
        <h2>What Is Contractor Financing?</h2>
        <p>Contractor financing refers to funding options construction businesses use to manage cash flow between project payments. Because labor, materials, and equipment often need to be paid before invoices are collected, contractors sometimes use working capital, equipment financing, or business credit to bridge the gap.</p>
      </div>
    </div>
  </section>

  <!-- 3. Common Contractor Cash Flow Problems -->
  <section class="section section-problems">
    <div class="container">
      <p class="section-eyebrow">The problem</p>
      <h2 class="section-title">Common Contractor Cash Flow Problems</h2>
      <p class="section-intro">Construction businesses spend money before they receive it. Payroll, materials, and overhead hit on fixed schedules while client payments often arrive weeks or months later. These timing gaps create pressure even when jobs are profitable.</p>
      <div class="problems-grid">
        {cashFlowProblems.map((item) => (
          <a href={item.href} class="problem-card">
            <span class="problem-icon" aria-hidden="true">
              {item.icon === "payroll" && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
              {item.icon === "invoice" && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>}
              {item.icon === "materials" && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>}
              {item.icon === "equipment" && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>}
              {item.icon === "startup" && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
            </span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <span class="problem-card-link">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Contractor Cash Flow Diagram -->
  <section class="section section-diagram">
    <div class="container">
      <p class="section-eyebrow">How it works</p>
      <h2 class="section-title">Why Contractor Cash Flow Gaps Happen</h2>
      <div class="diagram-wrapper">
        <ol class="payment-cycle" role="list">
          {paymentCycleSteps.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
        <p class="diagram-label">Cash Flow Gap</p>
      </div>
      <div class="diagram-explanation">
        <p>Construction payment cycles rarely align with expense cycles. Commercial and government projects often use net-30, net-60, or net-90 payment terms. Contractors complete work, submit invoices, and wait weeks or months for payment. Meanwhile, payroll, materials, and equipment costs are due on fixed schedules.</p>
        <p>Contractors feel pressure even when jobs are profitable. The business may be sound on paper, but timing creates real cash shortages. Understanding why this happens helps contractors plan and choose the right solutions.</p>
      </div>
    </div>
  </section>

  <!-- 5. Funding Options -->
  <section class="section section-funding">
    <div class="container">
      <p class="section-eyebrow">The options</p>
      <h2 class="section-title">Funding Options Contractors Sometimes Use</h2>
      <p class="section-intro">Different funding tools solve different contractor cash-flow situations. The right fit depends on whether the issue is payroll timing, equipment needs, material purchases, or project growth.</p>
      <div class="funding-grid">
        {fundingOptions.map((c) => (
          <a href={c.href} class="card card-funding">
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
            <span class="card-cta">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Trust / Authority Section -->
  <section class="section section-trust">
    <div class="container">
      <p class="section-eyebrow">Why this resource</p>
      <h2 class="section-title">Why Contractors Use These Guides</h2>
      <ul class="trust-list">
        {trustPoints.map((point) => (
          <li>{point}</li>
        ))}
      </ul>
      <p class="trust-note">These guides are designed to help contractors understand their options before making any decision.</p>
    </div>
  </section>

  <!-- 7. Latest Guides / Blog Preview -->
  {latestPosts.length > 0 && (
    <section class="section section-latest">
      <div class="container">
        <p class="section-eyebrow">From the guides</p>
        <h2 class="section-title">Latest Contractor Cash Flow Guides</h2>
        <div class="latest-grid">
          {latestPosts.map((post) => (
            <a href={post.data.canonicalPath} class="card card-latest">
              <p class="card-date">{post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</p>
              <h3>{post.data.title}</h3>
              <p>{post.data.excerpt}</p>
              <span class="card-cta">Read article →</span>
            </a>
          ))}
        </div>
        <p class="section-footer"><a href="/blog" class="btn-link">View all articles</a></p>
      </div>
    </section>
  )}

  <!-- 8. FAQ Section -->
  <section class="section section-faq">
    <div class="container">
      <p class="section-eyebrow">Common questions</p>
      <h2 class="section-title">Common Questions Contractors Ask</h2>
      <dl class="faq-list">
        {faq.map((item) => (
          <>
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </>
        ))}
      </dl>
    </div>
  </section>

  <!-- 9. Final CTA Section -->
  <section class="section section-cta-final">
    <div class="container">
      <p class="section-eyebrow">Next step</p>
      <h2 class="section-title">Explore Contractor Funding Options</h2>
      <p class="cta-copy">If your construction business is dealing with payroll gaps, invoice delays, material deposits, or equipment costs, reviewing available options can help you understand what may fit before making any decision.</p>
      <p class="cta-reassurance">{site.ctaReassurance}</p>
      <a class="btn btn-cta" href="https://axiantpartners.com/match" rel="sponsored noopener noreferrer" target="_blank">See what contractor funding options may be available</a>
    </div>
  </section>

  <style>
    .section { padding: 80px 0; }
    .section-title { font-family: 'Oswald', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--charcoal); margin: 0 0 20px 0; line-height: 1.2; max-width: 720px; }
    .section-eyebrow { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cta); margin: 0 0 16px 0; }
    .section-intro { font-size: 1.1rem; color: var(--concrete); max-width: 680px; margin: 0 0 36px 0; line-height: 1.75; }
    .section-footer { margin: 32px 0 0 0; }
    .container-narrow { max-width: 720px; }

    .hero-banner { position: relative; min-height: 520px; display: flex; align-items: center; width: 100%; }
    .hero-bg { position: absolute; inset: 0; }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(110deg, rgba(10,10,10,.98) 0%, rgba(18,18,18,.95) 30%, rgba(28,28,28,.88) 60%, rgba(35,35,35,.85) 100%); pointer-events: none; }
    .hero-bg { pointer-events: none; }
    .hero-content { position: relative; z-index: 1; color: #fff; padding: 80px 24px; width: 100%; max-width: 100%; box-sizing: border-box; }
    .hero-eyebrow { font-size: 0.85rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cta); margin: 0 0 20px 0; }
    .hero-content h1 { font-family: 'Oswald', sans-serif; color: #fff; margin: 0 0 24px 0; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; max-width: 680px; line-height: 1.1; }
    .hero-subheading { font-size: 1.2rem; font-weight: 600; color: #fff; margin: 0 0 14px 0; max-width: 560px; line-height: 1.45; }
    .hero-desc { color: #e5e7eb; max-width: 560px; margin: 0 0 32px 0; font-size: 1.05rem; line-height: 1.7; }
    .hero-cta { display: flex; flex-direction: column; gap: 20px; align-items: flex-start; }
    .btn-hero { padding: 18px 36px; font-size: 1rem; background: var(--cta) !important; color: #fff !important; letter-spacing: 0.04em; }
    .hero-link-secondary { color: #94a3b8; font-size: 0.95rem; text-decoration: underline; text-underline-offset: 3px; }
    .hero-link-secondary:hover { color: var(--cta); }

    .section-quick { background: var(--surface); padding: 64px 0; }
    .quick-answer { background: linear-gradient(90deg, rgba(242,101,34,.08) 0%, transparent 100%); border-left: 4px solid var(--cta); padding: 28px 32px; margin-bottom: 40px; border-radius: 0 6px 6px 0; }
    .quick-answer p { margin: 0; font-size: 1.1rem; line-height: 1.75; color: var(--text); }
    .definition-block { padding: 32px 0 0; border-top: 1px solid var(--border); }
    .definition-block h2 { font-family: 'Oswald', sans-serif; font-size: 1.5rem; margin: 0 0 16px 0; color: var(--charcoal); letter-spacing: 0.03em; text-transform: uppercase; }
    .definition-block p { margin: 0; font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 720px; }

    .section-problems { background: var(--bg); }
    .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; margin-top: 40px; }
    .problem-card { display: flex; flex-direction: column; background: var(--surface); border: 2px solid var(--border); border-radius: 6px; padding: 32px; transition: border-color .2s, box-shadow .2s, transform .1s; text-decoration: none; color: inherit; }
    .problem-card:hover { border-color: var(--cta); box-shadow: 0 12px 32px rgba(0,0,0,.08); }
    .problem-icon { display: flex; align-items: center; justify-content: flex-start; margin-bottom: 20px; color: var(--cta); }
    .problem-card h3 { font-family: 'Oswald', sans-serif; font-size: 1.2rem; font-weight: 600; margin: 0 0 12px 0; color: var(--charcoal); letter-spacing: 0.02em; text-transform: uppercase; }
    .problem-card p { font-size: 1rem; color: var(--concrete); margin: 0 0 20px 0; line-height: 1.6; flex: 1; }
    .problem-card-link { font-size: 0.95rem; font-weight: 600; color: var(--cta); }

    .section-diagram { background: var(--surface); }
    .diagram-wrapper { background: var(--surface-alt); border: 2px solid var(--border); border-radius: 8px; padding: 48px 40px; margin-bottom: 40px; max-width: 520px; }
    .payment-cycle { list-style: none; padding: 0; margin: 0; counter-reset: step; }
    .payment-cycle li { position: relative; padding: 14px 0 14px 48px; font-family: 'Oswald', sans-serif; font-size: 1.1rem; font-weight: 600; color: var(--charcoal); counter-increment: step; }
    .payment-cycle li::before { content: counter(step); position: absolute; left: 0; width: 30px; height: 30px; background: var(--cta); color: #fff; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; }
    .payment-cycle li:not(:last-child)::after { content: ""; position: absolute; left: 14px; top: 48px; bottom: -2px; width: 2px; background: linear-gradient(180deg, var(--cta) 0%, var(--border) 100%); }
    .diagram-label { font-family: 'Oswald', sans-serif; font-size: 1rem; font-weight: 600; color: var(--cta); margin: 20px 0 0 0; letter-spacing: 0.08em; }
    .diagram-explanation { max-width: 680px; }
    .diagram-explanation p { font-size: 1.05rem; line-height: 1.8; color: var(--text); margin: 0 0 18px 0; }
    .diagram-explanation p:last-child { margin-bottom: 0; }

    .section-funding { background: var(--bg); }
    .funding-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; margin-top: 40px; }
    .card-funding { display: flex; flex-direction: column; background: var(--surface); border: 2px solid var(--border); border-radius: 6px; padding: 32px; text-decoration: none; color: inherit; transition: border-color .2s, box-shadow .2s; }
    .card-funding:hover { border-color: var(--cta); box-shadow: 0 12px 32px rgba(0,0,0,.08); }
    .card-funding h3 { font-family: 'Oswald', sans-serif; font-size: 1.2rem; margin: 0 0 14px 0; color: var(--charcoal); letter-spacing: 0.02em; text-transform: uppercase; }
    .card-funding p { font-size: 1rem; color: var(--concrete); margin: 0 0 20px 0; line-height: 1.6; flex: 1; }
    .card-funding .card-cta { font-size: 0.95rem; font-weight: 600; color: var(--cta); }

    .section-trust { background: var(--charcoal); color: #fff; }
    .section-trust .section-eyebrow { color: var(--cta); }
    .section-trust .section-title { color: #fff; }
    .trust-list { list-style: none; padding: 0; margin: 0 0 28px 0; max-width: 560px; }
    .trust-list li { position: relative; padding: 14px 0 14px 36px; font-size: 1.05rem; line-height: 1.55; color: #e5e7eb; }
    .trust-list li::before { content: ""; position: absolute; left: 0; top: 20px; width: 8px; height: 8px; background: var(--cta); border-radius: 2px; }
    .trust-note { font-size: 1rem; color: #94a3b8; font-style: italic; margin: 0; max-width: 520px; }

    .section-latest { background: var(--bg); }
    .latest-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; margin-top: 40px; }
    .card-latest { display: flex; flex-direction: column; padding: 32px; background: var(--surface); border: 2px solid var(--border); border-radius: 6px; text-decoration: none; color: inherit; transition: border-color .2s, box-shadow .2s; }
    .card-latest:hover { border-color: var(--cta); box-shadow: 0 8px 24px rgba(0,0,0,.06); }
    .card-latest .card-date { font-size: 0.85rem; color: var(--concrete); margin: 0 0 12px 0; letter-spacing: 0.02em; }
    .card-latest h3 { font-family: 'Oswald', sans-serif; font-size: 1.15rem; margin: 0 0 12px 0; color: var(--charcoal); line-height: 1.35; }
    .card-latest p { font-size: 0.98rem; color: var(--concrete); margin: 0 0 18px 0; line-height: 1.55; flex: 1; }
    .card-latest .card-cta { font-size: 0.95rem; font-weight: 600; color: var(--cta); }

    .section-faq { background: var(--surface); }
    .faq-list { margin: 0; max-width: 720px; }
    .faq-list dt { font-family: 'Oswald', sans-serif; font-size: 1.1rem; font-weight: 600; color: var(--charcoal); margin: 28px 0 10px 0; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
    .faq-list dt:first-of-type { margin-top: 0; }
    .faq-list dd { margin: 0 0 0 0; font-size: 1.05rem; line-height: 1.75; color: var(--text); }

    .section-cta-final { background: var(--charcoal); color: #fff; }
    .section-cta-final .section-eyebrow { color: var(--cta); }
    .section-cta-final .section-title { color: #fff; }
    .cta-copy { font-size: 1.1rem; color: #e5e7eb; max-width: 600px; margin: 0 0 18px 0; line-height: 1.75; }
    .cta-reassurance { font-size: 0.95rem; color: #94a3b8; font-style: italic; margin: 0 0 28px 0; }
    .btn-cta { padding: 18px 36px; font-size: 1rem; background: var(--cta) !important; color: #fff !important; letter-spacing: 0.04em; }

    @media (max-width: 768px) {
      .section { padding: 56px 0; }
      .hero-banner { min-height: 440px; }
      .hero-content { padding: 56px 20px; }
      .problems-grid, .funding-grid, .latest-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
