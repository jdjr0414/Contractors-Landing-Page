---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { getCollection } from "astro:content";
import { site, fundingLinks, problemLinks } from "../data/site";
import { breadcrumbSchema } from "../utils/breadcrumbs";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages
    .filter((entry) => entry.slug !== "home" && entry.slug !== "glossary")
    .map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const rawCanonicalPath = (entry.data as { canonicalPointsTo?: string }).canonicalPointsTo ?? entry.data.canonicalPath;
const canonicalPath = rawCanonicalPath.startsWith("/") ? rawCanonicalPath : `/${rawCanonicalPath}`;
const canonicalPathWithSlash = canonicalPath.endsWith("/") ? canonicalPath : `${canonicalPath}/`;
const canonicalUrl = new URL(canonicalPathWithSlash, site.domain).toString();
const faq = entry.data.faq ?? [];
const faqSchema = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
} : null;

const defaultImage = "https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=1200&q=80";
const pageImage = entry.data.imageUrl ?? defaultImage;
const hasPartItems = [
  ...(entry.data.quickAnswer ? [{ "@type": "WebPageElement" as const, name: "Quick answer", description: entry.data.quickAnswer }] : []),
  ...(entry.data.keyTakeaway ? [{ "@type": "WebPageElement" as const, name: "Key takeaway", description: entry.data.keyTakeaway }] : [])
];
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: entry.data.title,
  description: entry.data.description,
  url: canonicalUrl,
  ...(entry.data.dateModified ? { dateModified: entry.data.dateModified.toISOString() } : {}),
  author: { "@type": "Organization", name: entry.data.author ?? site.author },
  publisher: { "@type": "Organization", name: site.name, url: new URL("/", site.domain).toString() },
  about: { "@type": "Thing", name: entry.data.h1 ?? entry.data.title },
  image: pageImage,
  ...(entry.data.quickAnswer ? { abstract: entry.data.quickAnswer } : {}),
  ...(hasPartItems.length > 0 ? { hasPart: hasPartItems } : {}),
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["main .quick-answer", "main .hero p", "main .key-takeaway", "main .prose p", "main .prose h2", "main .prose h3"]
  }
};

const baseUrl = new URL("/", site.domain).toString();
const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: entry.data.title, url: entry.data.canonicalPath }
];
const breadcrumbSchemaJson = breadcrumbSchema(breadcrumbItems, baseUrl);

const glossaryTerms = (entry.data as { glossaryTerms?: Array<{ term: string; definition: string }> }).glossaryTerms;
const definedTermSetSchema = glossaryTerms?.length ? {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: "Contractor Financing Glossary",
  description: "Definitions of key terms in contractor financing and cash flow.",
  hasDefinedTerm: glossaryTerms.map((t) => ({
    "@type": "DefinedTerm",
    name: t.term,
    description: t.definition
  }))
} : null;

const fundingOptionsTableSchema = entry.slug === "all-funding-options" ? {
  "@context": "https://schema.org",
  "@type": "Table",
  name: "Contractor Funding Options by Type",
  about: { "@type": "Thing", name: "Contractor financing options: working capital, equipment financing, line of credit, payroll funding, business loans, accounts receivable" },
  description: "Comparison of contractor funding options by type, best use case, and link to full guide."
} : null;
---
<BaseLayout title={entry.data.title} description={entry.data.description} canonicalUrl={canonicalUrl} ogType={entry.data.ogType}>
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchemaJson)} slot="head" />
  {definedTermSetSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(definedTermSetSchema)} slot="head" />
  )}
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}
  {fundingOptionsTableSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(fundingOptionsTableSchema)} slot="head" />
  )}
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <span aria-hidden="true"> / </span>
      <span>{entry.data.title}</span>
    </div>
  </nav>
  <section class="hero hero-page">
    <div class="hero-page-bg"></div>
    <div class="container hero-page-content">
      <div class="hero-meta">
        {entry.data.dateModified && (
          <p class="last-updated">Last updated: {entry.data.dateModified.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
        )}
        <p class="author-byline">By {entry.data.author ?? site.author}</p>
      </div>
      <h1>{entry.data.h1 ?? entry.data.title}</h1>
      {entry.data.intro && <p>{entry.data.intro}</p>}
    </div>
  </section>
  <section class="section">
    <article class={`container prose ${entry.slug === "glossary" ? "glossary-page" : ""}`}>
    {entry.data.quickAnswer && (
      <div class="quick-answer" role="complementary" aria-label="Quick answer">
        <p><strong>Quick answer:</strong> {entry.data.quickAnswer}</p>
      </div>
    )}
    {entry.slug === "contact" && (
      <section aria-label="Request a call back">
        <ContactForm />
      </section>
    )}
    <Content />
    {faq.length > 0 && (
      <>
        <h2>Frequently asked questions</h2>
        {faq.map((item: { question: string; answer: string }) => (
          <>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </>
        ))}
      </>
    )}
    {entry.data.keyTakeaway && (
      <div class="key-takeaway" role="complementary" aria-label="Key takeaway">
        <h3>Key takeaway</h3>
        <p>{entry.data.keyTakeaway}</p>
      </div>
    )}
    {(entry.data.relatedProblems?.length > 0 || entry.data.relatedSolutions?.length > 0) && (
      <div class="related-links">
        {entry.data.relatedProblems?.length > 0 && (
          <div>
            <h3>Related problems</h3>
            <ul>
              {entry.data.relatedProblems.map((path) => {
                const link = problemLinks.find((l) => l.href === path) ?? { href: path, label: path.replace(/^\//, "").replace(/-/g, " ") };
                return <li><a href={link.href}>{link.label}</a></li>;
              })}
            </ul>
          </div>
        )}
        {entry.data.relatedSolutions?.length > 0 && (
          <div>
            <h3>Related solutions</h3>
            <ul>
              {entry.data.relatedSolutions.map((path) => {
                const link = fundingLinks.find((l) => l.href === path) ?? { href: path, label: path.replace(/^\//, "").replace(/-/g, " ") };
                return <li><a href={link.href}>{link.label}</a></li>;
              })}
            </ul>
          </div>
        )}
      </div>
    )}
    <div class="cta">
      <h2>{entry.data.ctaTitle ?? "Explore contractor funding options"}</h2>
      <p>{entry.data.ctaText ?? "See what funding options may be available for your construction business."}</p>
      <p class="cta-reassurance">{site.ctaReassurance}</p>
      <p class="cta-disclaimer">{site.ctaDisclaimer}</p>
      <div class="cta-actions">
        <a class="btn" href={site.ctaUrl} rel="sponsored noopener noreferrer" target="_blank">{site.ctaText}</a>
        <a href="/contact/" class="btn btn-secondary">Talk to Someone First — Free Call</a>
      </div>
      <p class="cta-phone">
        Or call/text directly:{" "}
        <a href={site.phoneHref}>{site.phone}</a>
      </p>
    </div>
  </article>
  </section>
</BaseLayout>
