---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { site } from "../../data/site";
import { breadcrumbSchema } from "../../utils/breadcrumbs";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const canonicalUrl = new URL("/blog", site.domain).toString();
const baseUrl = new URL("/", site.domain).toString();

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" }
];
const breadcrumbSchemaJson = breadcrumbSchema(breadcrumbItems, baseUrl);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Contractor Financing Blog Articles",
  description: "Practical guides on contractor payroll, equipment financing, cash flow, receivables, and funding options.",
  numberOfItems: posts.length,
  itemListElement: posts.map((post, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: new URL(post.data.canonicalPath, site.domain).toString(),
    name: post.data.title
  }))
};
---
<BaseLayout
  title="Contractor Financing Blog | Payroll, Equipment & Cash Flow 2025"
  description="Contractor financing blog: payroll gaps, equipment financing, cash flow, receivables. Working capital, LOC & business loans. 2025 guides."
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchemaJson)} slot="head" />
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <span aria-hidden="true"> / </span>
      <span>Blog</span>
    </div>
  </nav>
  <section class="hero hero-blog">
    <div class="hero-blog-bg">
      <img src="https://images.unsplash.com/photo-1756388812709-3d524bc42b9b?w=1200&q=80" alt="" />
      <div class="hero-blog-overlay"></div>
    </div>
    <div class="container hero-blog-content">
      <h1>Contractor Cash Flow & Funding Guides</h1>
      <p>
        Practical articles for contractors dealing with payroll timing, receivables, job-cost pressure, material purchases,
        and equipment issues. Start with the core guides on <a href="/contractor-working-capital">contractor working capital</a>,
        <a href="/construction-equipment-financing"> equipment financing</a>, and
        <a href="/contractor-line-of-credit"> contractor lines of credit</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid" style="gap:16px;">
    {posts.map((post) => (
      <div class="card card-img">
        <div class="card-image">
          <img src="https://images.unsplash.com/photo-1748848436533-f7583dce22b6?w=400&q=80" alt="" loading="lazy" />
        </div>
        <div class="card-body">
          <p class="small">{post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</p>
          <strong>{post.data.title}</strong>
          <p>{post.data.excerpt}</p>
          <a class="btn-link" href={post.data.canonicalPath}>Read article</a>
        </div>
      </div>
    ))}
    </div>
  </section>

  <style>
    .hero-blog { position: relative; min-height: 200px; display: flex; align-items: center; width: 100%; }
    .hero-blog-bg { position: absolute; inset: 0; }
    .hero-blog-bg img { width: 100%; height: 100%; object-fit: cover; }
    .hero-blog-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(43,43,43,.92) 0%, rgba(43,43,43,.7) 60%, rgba(242,101,34,.15) 100%); pointer-events: none; }
    .hero-blog-content { position: relative; z-index: 1; color: #fff; padding: 32px 0; width: 100%; max-width: 100%; box-sizing: border-box; }
    .hero-blog-content h1 { font-family: 'Oswald', sans-serif; color: #fff; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; font-weight: 600; margin-bottom: 20px; }
    .hero-blog-content p { color: #e2e8f0; font-size: 1.125rem; line-height: 1.75; max-width: 75ch; }
    .hero-blog-content a { display: inline-block; padding: 6px 12px; background: rgba(255,255,255,.2); color: #fff !important; border-radius: 6px; border: 1px solid rgba(255,255,255,.3); margin: 2px 4px 2px 0; }
    .hero-blog-content a:hover { background: rgba(255,255,255,.3); }
  </style>
</BaseLayout>
