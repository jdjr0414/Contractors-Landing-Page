---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { site } from "../../data/site";
import { breadcrumbSchema } from "../../utils/breadcrumbs";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const canonicalUrl = new URL("/blog", site.domain).toString();

/** Verified working Unsplash construction/contractor images. Use post.data.imageUrl when set (e.g. /images/blog/foo.jpg). */
const blogCardImages = [
  "https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=400&q=80",
  "https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=400&q=80",
  "https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=400&q=80",
  "https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=400&q=80",
  "https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=400&q=80",
  "https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?w=400&q=80",
  "https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=400&q=80",
  "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=400&q=80",
  "https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=400&q=80",
  "https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=400&q=80",
  "https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=400&q=80",
  "https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=400&q=80",
  "https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=400&q=80",
  "https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?w=400&q=80",
  "https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=400&q=80",
  "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=400&q=80",
  "https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=400&q=80",
  "https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=400&q=80",
  "https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=400&q=80"
];

function getImageSrc(post: (typeof posts)[0], index: number): string {
  const url = post.data.imageUrl;
  if (url && url.startsWith("/")) return url;
  if (url && (url.startsWith("http://") || url.startsWith("https://"))) return url;
  return blogCardImages[index % blogCardImages.length];
}

function getImageAlt(post: (typeof posts)[0]): string {
  return `Article: ${post.data.title}`;
}

const baseUrl = new URL("/", site.domain).toString();

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" }
];
const breadcrumbSchemaJson = breadcrumbSchema(breadcrumbItems, baseUrl);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Contractor Financing Blog Articles",
  description: "Practical guides on contractor payroll, equipment financing, cash flow, receivables, and funding options.",
  numberOfItems: posts.length,
  itemListElement: posts.map((post, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: new URL(post.data.canonicalPath, site.domain).toString(),
    name: post.data.title
  }))
};
---
<BaseLayout
  title="Contractor Financing Blog | Payroll, Equipment & Cash Flow 2026"
  description="Contractor financing blog: payroll gaps, equipment financing, cash flow, receivables. Working capital, LOC & business loans. 2026 guides."
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchemaJson)} slot="head" />
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <span aria-hidden="true"> / </span>
      <span>Blog</span>
    </div>
  </nav>
  <section class="hero hero-blog">
    <div class="hero-blog-bg">
      <img src="https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=1200&q=80" alt="Contractor financing and cash flow guides" />
      <div class="hero-blog-overlay"></div>
    </div>
    <div class="container hero-blog-content">
      <h1>Contractor Cash Flow & Funding Guides</h1>
      <p>
        Practical articles for contractors dealing with payroll timing, receivables, job-cost pressure, material purchases,
        and equipment issues. Start with the core guides on <a href="/contractor-working-capital">contractor working capital</a>,
        <a href="/construction-equipment-financing"> equipment financing</a>, and
        <a href="/contractor-line-of-credit"> contractor lines of credit</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post, i) => {
          const imgSrc = getImageSrc(post, i);
          const dateStr = post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
          const isoDate = post.data.pubDate.toISOString().split("T")[0];
          return (
            <article class="blog-card">
              <img
                src={imgSrc}
                alt={getImageAlt(post)}
                loading="lazy"
                width="400"
                height="225"
              />
              <h2>
                <a href={post.data.canonicalPath}>
                  {post.data.title}
                </a>
              </h2>
              <time datetime={isoDate}>{dateStr}</time>
              <p>{post.data.excerpt}</p>
              <a class="read-more" href={post.data.canonicalPath}>
                Read article
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <style>
    .hero-blog { position: relative; min-height: 200px; display: flex; align-items: center; width: 100%; }
    .hero-blog-bg { position: absolute; inset: 0; }
    .hero-blog-bg img { width: 100%; height: 100%; object-fit: cover; }
    .hero-blog-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(43,43,43,.92) 0%, rgba(43,43,43,.7) 60%, rgba(242,101,34,.15) 100%); pointer-events: none; }
    .hero-blog-content { position: relative; z-index: 1; color: #fff; padding: 32px 0; width: 100%; max-width: 100%; box-sizing: border-box; }
    .hero-blog-content h1 { font-family: 'Oswald', sans-serif; color: #fff; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; font-weight: 600; margin-bottom: 20px; }
    .hero-blog-content p { color: #e2e8f0; font-size: 1.125rem; line-height: 1.75; max-width: 75ch; }
    .hero-blog-content a { display: inline-block; padding: 6px 12px; background: rgba(255,255,255,.2); color: #fff !important; border-radius: 6px; border: 1px solid rgba(255,255,255,.3); margin: 2px 4px 2px 0; }
    .hero-blog-content a:hover { background: rgba(255,255,255,.3); }

    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 28px;
      margin-top: 32px;
    }

    .blog-card {
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 2px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: var(--shadow-card);
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .blog-card:hover {
      border-color: var(--cta);
      box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .blog-card img {
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      display: block;
    }

    .blog-card h2 {
      font-family: 'Oswald', sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.3;
      margin: 20px 20px 8px;
      color: var(--charcoal);
    }

    .blog-card h2 a {
      color: inherit;
      text-decoration: none;
    }

    .blog-card h2 a:hover {
      color: var(--cta);
    }

    .blog-card time {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin: 0 20px 12px;
      display: block;
    }

    .blog-card > p {
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--text);
      margin: 0 20px 16px;
      flex: 1;
    }

    .blog-card .read-more {
      display: inline-block;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--cta);
      margin: 0 20px 20px;
      padding: 8px 0;
    }

    .blog-card .read-more:hover {
      text-decoration: underline;
    }
  </style>
</BaseLayout>
