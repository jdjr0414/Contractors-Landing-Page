---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = (await getCollection("blog"))
  .filter((p) => p.slug !== entry.slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const relatedPosts = allPosts.slice(0, 3);
const canonicalUrl = new URL(entry.data.canonicalPath, site.domain).toString();
const faqSchema = entry.data.faq.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: entry.data.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer }
      }))
    }
  : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.dateModified ?? entry.data.pubDate).toISOString(),
  author: { "@type": "Organization", name: entry.data.author },
  publisher: { "@type": "Organization", name: site.name, url: new URL("/", site.domain).toString() },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  url: canonicalUrl,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["main .hero p", "main .prose p"]
  }
};
---
<BaseLayout title={entry.data.title} description={entry.data.description} canonicalUrl={canonicalUrl} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}
  <section class="hero hero-post">
    <div class="hero-post-img">
      <img src="https://images.unsplash.com/photo-1678944827354-fb54b9040a04?w=1200&q=80" alt="" />
      <div class="hero-post-overlay"></div>
    </div>
    <div class="container hero-post-content">
      <p class="small">{entry.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.excerpt}</p>
    </div>
  </section>

  <article class="container prose">
    <Content />
    <h2>Related guides</h2>
    <ul>
      <li><a href="/contractor-working-capital">Contractor Working Capital</a></li>
      <li><a href="/construction-equipment-financing">Construction Equipment Financing</a></li>
      <li><a href="/contractor-line-of-credit">Contractor Line of Credit</a></li>
    </ul>
    {relatedPosts.length > 0 && (
      <>
        <h2>More articles</h2>
        <ul>
          {relatedPosts.map((p) => (
            <li><a href={p.data.canonicalPath}>{p.data.title}</a></li>
          ))}
        </ul>
      </>
    )}
    <p><a href="/blog">← All blog articles</a></p>

    {entry.data.faq.length > 0 && (
      <>
        <h2>Frequently asked questions</h2>
        {entry.data.faq.map((item) => (
          <>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </>
        ))}
      </>
    )}

    <div class="cta">
      <h2>Exploring contractor funding options?</h2>
      <p>See what may be available for payroll, materials, receivables gaps, or equipment needs.</p>
      <a class="btn" href={site.ctaUrl} rel="sponsored noopener noreferrer" target="_blank">{site.ctaText}</a>
    </div>
  </article>

  <style>
    .hero-post { position: relative; min-height: 320px; display: flex; align-items: flex-end; width: 100%; margin-bottom: 32px; }
    .hero-post-img { position: absolute; inset: 0; }
    .hero-post-img img { width: 100%; height: 100%; object-fit: cover; }
    .hero-post-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(43,43,43,.95) 0%, rgba(43,43,43,.5) 50%, transparent 100%); }
    .hero-post-content { position: relative; z-index: 1; color: #fff; padding: 48px 20px 40px; width: 100%; max-width: 100%; box-sizing: border-box; overflow-wrap: break-word; }
    .hero-post-content h1 { font-family: 'Oswald', sans-serif; color: #fff; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; }
    .hero-post-content .small { color: #94a3b8; }
    .hero-post-content p { color: #e2e8f0; }
  </style>
</BaseLayout>
