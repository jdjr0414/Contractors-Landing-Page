---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { site, fundingLinks } from "../../data/site";
import { breadcrumbSchema } from "../../utils/breadcrumbs";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = (await getCollection("blog"))
  .filter((p) => p.slug !== entry.slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const relatedPosts = allPosts.slice(0, 3);
const canonicalUrl = new URL(entry.data.canonicalPath, site.domain).toString();
const baseUrl = new URL("/", site.domain).toString();

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" },
  { name: entry.data.title, url: entry.data.canonicalPath }
];
const breadcrumbSchemaJson = breadcrumbSchema(breadcrumbItems, baseUrl);

const faqSchema = entry.data.faq.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: entry.data.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer }
      }))
    }
  : null;

const articleImage = entry.data.imageUrl ?? "https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=1200&q=80";
const articleImageAlt = `Article about ${entry.data.title}`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.dateModified ?? entry.data.pubDate).toISOString(),
  author: { "@type": "Organization", name: entry.data.author },
  publisher: { "@type": "Organization", name: site.name, url: baseUrl, logo: { "@type": "ImageObject", url: articleImage } },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  url: canonicalUrl,
  image: { "@type": "ImageObject", url: articleImage, caption: entry.data.title },
  about: { "@type": "Thing", name: entry.data.category ?? "Contractor Financing" },
  ...(entry.data.quickAnswer ? { abstract: entry.data.quickAnswer } : {}),
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["main .hero p", "main .prose p", "main .quick-answer"]
  }
};

const relatedFundingPaths = entry.data.relatedFunding?.length ? entry.data.relatedFunding : [
  "/contractor-working-capital",
  "/construction-equipment-financing",
  "/contractor-line-of-credit"
];
const relatedFunding = fundingLinks.filter((f) => relatedFundingPaths.includes(f.href));
const uniqueFunding = [...new Map(relatedFunding.map((f) => [f.href, f])).values()].slice(0, 3);
const defaultFunding = fundingLinks.slice(0, 5);
const fundingToShow = uniqueFunding.length > 0 ? uniqueFunding : defaultFunding;
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  imageUrl={entry.data.imageUrl ?? articleImage}
  articlePublishedTime={entry.data.pubDate.toISOString()}
  articleModifiedTime={(entry.data.dateModified ?? entry.data.pubDate).toISOString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchemaJson)} slot="head" />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <span aria-hidden="true"> / </span>
      <a href="/blog/">Blog</a>
      <span aria-hidden="true"> / </span>
      <span>{entry.data.title}</span>
    </div>
  </nav>
  <section class="hero hero-post">
    <div class="hero-post-img">
      <img src={articleImage} alt={articleImageAlt} loading="eager" width="1200" height="630" />
      <div class="hero-post-overlay"></div>
    </div>
    <div class="container hero-post-content">
      <div class="hero-meta">
        <p class="small">{entry.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
        {entry.data.dateModified && entry.data.dateModified.getTime() !== entry.data.pubDate.getTime() && (
          <p class="last-updated">Updated {entry.data.dateModified.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
        )}
        <p class="author-byline">By {entry.data.author}</p>
      </div>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.excerpt}</p>
    </div>
  </section>

  <section class="section">
  <article class="container prose">
    {entry.data.quickAnswer && (
      <div class="quick-answer" role="complementary" aria-label="Quick answer">
        <p><strong>Quick answer:</strong> {entry.data.quickAnswer}</p>
      </div>
    )}
    <Content />
    <h2>Related funding guides</h2>
    <ul>
      {fundingToShow.map((f) => (
        <li><a href={f.href}>{f.label}</a></li>
      ))}
    </ul>
    {relatedPosts.length > 0 && (
      <>
        <h2>More articles</h2>
        <ul>
          {relatedPosts.map((p) => (
            <li><a href={p.data.canonicalPath}>{p.data.title}</a></li>
          ))}
        </ul>
      </>
    )}
    <p><a href="/blog/">← All blog articles</a></p>

    {entry.data.faq.length > 0 && (
      <>
        <h2>Frequently asked questions</h2>
        {entry.data.faq.map((item) => (
          <>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </>
        ))}
      </>
    )}

    <div class="cta">
      <h2>Explore contractor funding options</h2>
      <p>See what funding options may be available for payroll, materials, receivables gaps, or equipment needs.</p>
      <p class="cta-reassurance">{site.ctaReassurance}</p>
      <p class="cta-disclaimer">{site.ctaDisclaimer}</p>
      <a class="btn" href={site.ctaUrl} rel="sponsored noopener noreferrer" target="_blank">{site.ctaText}</a>
    </div>
  </article>
  </section>

  <style>
    .quick-answer { background: var(--surface-alt); border-left: 4px solid var(--cta); padding: 16px 28px; margin-bottom: 2rem; border-radius: 4px; }
    .quick-answer p { margin: 0; font-size: 1.05rem; line-height: 1.6; }
    .section-intro { font-size: 0.95rem; color: var(--concrete); margin: -0.5rem 0 1rem 0; line-height: 1.5; }
    .hero-post { position: relative; min-height: 320px; display: flex; align-items: flex-end; width: 100%; margin-bottom: 32px; }
    .hero-post-img { position: absolute; inset: 0; }
    .hero-post-img img { width: 100%; height: 100%; object-fit: cover; }
    .hero-post-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(43,43,43,.95) 0%, rgba(43,43,43,.5) 50%, transparent 100%); }
    .hero-post-content { position: relative; z-index: 1; color: #fff; padding: 48px 0 40px; width: 100%; max-width: 100%; box-sizing: border-box; overflow-wrap: break-word; }
    .hero-post-content h1 { font-family: 'Oswald', sans-serif; color: #fff; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; font-weight: 600; margin-bottom: 20px; }
    .hero-post-content .small { color: #94a3b8; }
    .hero-post-content p { color: #e2e8f0; font-size: 1.125rem; line-height: 1.75; max-width: 75ch; }
  </style>
</BaseLayout>
