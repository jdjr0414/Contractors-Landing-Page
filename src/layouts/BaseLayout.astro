---
import SeoHead from "../components/SeoHead.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogType?: string;
  imageUrl?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}
const { title, description, canonicalUrl, ogType = "website", imageUrl, articlePublishedTime, articleModifiedTime } = Astro.props;

const baseUrl = new URL("/", site.domain).toString();
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": site.name,
  "url": baseUrl,
  "description": "Educational resource for contractor financing: working capital, equipment financing, business loans, and cash flow solutions for construction businesses.",
  "logo": "https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=512&q=80",
  "foundingDate": "2026",
  "areaServed": site.areaServed ?? "United States",
  ...(site.sameAs?.length ? { sameAs: site.sameAs } : {})
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.name,
  "url": baseUrl,
  "description": "Contractor financing guide: working capital, equipment loans, lines of credit, business loans. Funding for construction businesses.",
  "publisher": { "@type": "Organization", "name": site.name, "url": baseUrl },
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${baseUrl.replace(/\/$/, "")}/blog?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  },
  ...(site.sameAs?.length ? { sameAs: site.sameAs } : {})
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/logo_transparent_whitegear.png" type="image/png" />
    <link rel="sitemap" type="application/xml" href={new URL("/sitemap-index.xml", site.domain).toString()} title="Sitemap" />
    <SeoHead
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType={ogType}
  imageUrl={imageUrl}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
  twitterSite={site.twitterSite || undefined}
  twitterCreator={site.twitterCreator || undefined}
/>
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #f2f2f2;
        --surface: #ffffff;
        --surface-alt: #e5e5e5;
        --surface-concrete: #e0e0e0;
        --text: #1a1a1a;
        --text-muted: #4a4a4a;
        --brand: #e85c1a;
        --brand-hover: #c94f16;
        --cta: #e85c1a;
        --cta-hover: #c94f16;
        --border: #c9c9c9;
        --border-light: #d4d4d4;
        --charcoal: #0d0d0d;
        --concrete: #4a4a4a;
        --shadow: 0 1px 2px rgba(0,0,0,.08);
        --shadow-card: 0 2px 8px rgba(0,0,0,.06);
      }
      * { box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      body { margin: 0; font-family: 'Source Sans 3', system-ui, sans-serif; font-size: 18px; line-height: 1.75; color: var(--text); background: var(--bg); }
      img { max-width: 100%; height: auto; }
      a { color: inherit; text-decoration: none; }
      h1 { font-family: 'Oswald', sans-serif; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 20px; font-weight: 700; color: var(--charcoal); }
      h2 { font-family: 'Oswald', sans-serif; font-size: clamp(1.8rem, 3vw, 3rem); line-height: 1.1; margin-bottom: 18px; font-weight: 700; color: var(--charcoal); }
      h3 { font-family: 'Oswald', sans-serif; font-size: 1.3rem; margin-bottom: 14px; font-weight: 700; color: var(--charcoal); }
      p { margin-bottom: 20px; max-width: 75ch; }
      p:last-child { margin-bottom: 0; }
      .container { max-width: 1120px; margin: 0 auto; padding-left: 32px; padding-right: 32px; width: 100%; }
      header .container,
      footer .container { max-width: none; padding-left: 32px; padding-right: 32px; overflow: visible; }
      .section { padding-top: 72px; padding-bottom: 72px; }
      header {
        background: var(--charcoal);
        border-bottom: 4px solid var(--cta);
        box-shadow: 0 2px 8px rgba(0,0,0,.25);
        position: sticky;
        top: 0;
        z-index: 100;
        overflow: visible;
      }
      .nav { display: flex; flex-direction: column; gap: 0; padding: 0; position: relative; }
      .nav-row { display: flex; justify-content: space-between; align-items: center; gap: 24px; padding: 14px 0; flex-wrap: nowrap; min-width: 0; }
      .nav-row-1 { padding-top: 18px; }
      .nav-row-2 { padding-bottom: 18px; justify-content: center; border-top: 1px solid rgba(255,255,255,.15); }
      .nav .brand { flex-shrink: 0; }
      .nav ul { display: flex; flex: 1 1 auto; min-width: 0; justify-content: center; gap: 20px; list-style: none; padding: 0; margin: 0; flex-wrap: nowrap; }
      .nav a { color: #94a3b8; font-weight: 500; font-size: 0.85rem; white-space: nowrap; transition: color .2s; }
      .nav a:hover { color: #fff; }
      .brand { display: flex; align-items: center; gap: 12px; font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 1.35rem; color: #fff; letter-spacing: 0.04em; text-transform: uppercase; }
      .page-content { position: relative; }
      .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 8px; color: #fff; }
      .nav-toggle svg { width: 28px; height: 28px; }
      .nav-toggle[aria-expanded="true"] .nav-toggle-icon-open { display: none; }
      .nav-toggle[aria-expanded="true"] .nav-toggle-icon-close { display: block; }
      .nav-toggle .nav-toggle-icon-close { display: none; }
      @media (max-width: 1024px) {
        .nav-row-2 { display: none !important; }
        .nav-toggle { display: flex; align-items: center; justify-content: center; }
        .nav-menu { position: absolute; top: 100%; left: 0; right: 0; background: var(--charcoal); border-bottom: 4px solid var(--cta); max-height: 0; overflow: hidden; transition: max-height 0.3s ease; z-index: 99; }
        .nav-menu[data-open="true"] { max-height: 80vh; overflow-y: auto; }
        .nav ul { flex-direction: column; align-items: stretch; gap: 0; padding: 16px 0; }
        .nav ul li { border-bottom: 1px solid rgba(255,255,255,.1); }
        .nav ul li:last-child { border-bottom: none; }
        .nav ul a { display: block; padding: 14px 32px; font-size: 1rem; white-space: normal; }
        .nav-menu .nav-cta { display: block !important; padding: 16px 32px; margin: 16px 32px; text-align: center; background: var(--cta); color: #fff; border-radius: 4px; font-weight: 700; }
      }
      @media (min-width: 1025px) {
        .nav-menu { display: flex !important; flex: 1 1 auto !important; min-width: 0 !important; max-height: none !important; position: static !important; }
      }
      .btn {
        display: inline-block;
        width: auto;
        background: var(--cta);
        color: #fff !important;
        padding: 12px 24px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.9rem;
        font-family: 'Oswald', sans-serif;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: background .2s;
        border: none;
        cursor: pointer;
      }
      .btn:hover { background: var(--cta-hover); }
      .btn-link {
        display: inline-block;
        width: auto;
        background: var(--surface);
        color: var(--charcoal) !important;
        padding: 8px 14px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.9rem;
        border: 2px solid var(--border);
        transition: background .2s, border-color .2s;
      }
      .btn-link:hover { background: var(--surface-alt); border-color: var(--cta); color: var(--cta) !important; }
      .hero { padding: 28px 0 24px; }
      .hero h1 { font-family: 'Oswald', sans-serif; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 20px; font-weight: 600; }
      .hero p { font-size: 1.125rem; line-height: 1.75; color: var(--text-muted); max-width: 75ch; margin-bottom: 20px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; margin: 20px 0; }
      .card {
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 6px;
        padding: 24px;
        box-shadow: var(--shadow-card);
        transition: border-color .2s, box-shadow .2s;
        overflow: hidden;
      }
      .card:hover { border-color: var(--cta); box-shadow: 0 4px 12px rgba(0,0,0,.08); }
      main { padding-bottom: 56px; }
      article, .prose { max-width: 100%; overflow-wrap: break-word; word-wrap: break-word; }
      .prose h2 { font-family: 'Oswald', sans-serif; font-size: clamp(1.8rem, 3vw, 3rem); line-height: 1.1; margin-top: 2.5rem; margin-bottom: 18px; font-weight: 700; letter-spacing: -0.01em; color: var(--charcoal); }
      .prose h2:first-child { margin-top: 0; }
      .prose h3 { font-family: 'Oswald', sans-serif; font-size: 1.3rem; margin-top: 2rem; margin-bottom: 14px; font-weight: 700; color: var(--charcoal); }
      .prose ul, .prose ol { padding-left: 1.25rem; }
      .prose li { margin-bottom: 0.5rem; }
      .prose p { margin-bottom: 20px; line-height: 1.75; color: var(--text); max-width: 75ch; }
      .prose a {
        display: inline;
        background: var(--surface-alt);
        color: var(--charcoal) !important;
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 600;
        border: 1px solid var(--border);
        transition: background .2s, border-color .2s;
      }
      .prose a:hover { background: var(--surface); border-color: var(--cta); color: var(--cta) !important; }
      .prose ul a, .prose ol a { display: inline-block; margin: 4px 8px 4px 0; }
      .prose table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
      .prose th, .prose td { padding: 12px 14px; text-align: left; border: 1px solid var(--border); }
      .prose th { background: var(--surface-alt); font-weight: 600; }
      .prose tr:nth-child(even) { background: var(--surface); }
      .situations-table-wrapper { overflow-x: auto; margin: 1.25rem 0; -webkit-overflow-scrolling: touch; }
      .situations-table-wrapper table { min-width: 320px; }
      @media (max-width: 640px) {
        .prose th, .prose td { padding: 10px 12px; font-size: 0.9rem; }
      }
      .cta {
        background: var(--surface);
        border: 2px solid var(--cta);
        border-radius: 4px;
        padding: 24px;
        margin-top: 28px;
      }
      .cta h2 { font-family: 'Oswald', sans-serif; margin-top: 0 !important; font-size: 1.3rem; letter-spacing: 0.03em; text-transform: uppercase; color: var(--charcoal); }
      .cta-reassurance { font-size: 0.95rem; color: var(--concrete); margin: 0 0 16px 0; font-style: italic; }
      footer { padding: 56px 0 64px; background: var(--charcoal); color: #9ca3af; border-top: 4px solid var(--cta); }
      .footer-grid { display: grid; gap: 32px; }
      .footer-brand { font-size: 1rem; margin: 0; color: #e5e7eb; line-height: 1.5; }
      .footer-nav { display: flex; flex-wrap: nowrap; flex: 1 1 auto; justify-content: center; gap: 8px 20px; }
      .footer-nav a { color: #94a3b8; padding: 4px 8px; border-radius: 4px; white-space: nowrap; }
      .footer-nav a:hover { color: var(--cta); }
      .footer-legal { font-size: 0.9rem; margin: 0; opacity: .9; }
      .footer-legal a { color: #94a3b8; }
      .footer-legal a:hover { color: var(--cta); }
      .footer-disclosure { font-size: 0.8rem; margin: 0; opacity: .7; }
      .small { font-size: 0.85rem; color: var(--text-muted); }
      .hero-page { position: relative; overflow: hidden; border-left: 4px solid var(--cta); }
      .hero-page-bg { position: absolute; inset: 0; background: linear-gradient(135deg, var(--surface-alt) 0%, var(--surface) 100%); opacity: .95; }
      .hero-page-content { position: relative; z-index: 1; padding-top: 48px; padding-bottom: 48px; }
      .hero-page-content h1 { color: var(--charcoal); font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 20px; }
      .hero-page-content p { color: var(--concrete); font-size: 1.125rem; line-height: 1.75; margin-bottom: 20px; max-width: 75ch; }
      .card-img { padding: 0; display: block; }
      .card-img .card-image { aspect-ratio: 16/9; overflow: hidden; border-radius: 8px 8px 0 0; }
      .card-img .card-image img { width: 100%; height: 100%; object-fit: cover; transition: opacity .2s; }
      .card-img:hover .card-image img { opacity: .9; }
      .card-img .card-body { padding: 14px 16px; }
      .card-img .card-body strong { display: block; margin-bottom: 4px; font-size: 0.95rem; font-weight: 600; }
      .card-img .card-body p { margin: 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; }
      .breadcrumb { padding: 12px 0; font-size: 0.9rem; color: var(--text-muted); background: var(--surface-alt); }
      .breadcrumb a { color: var(--text-muted); }
      .breadcrumb a:hover { color: var(--text); }
      .breadcrumb span:last-child { color: var(--text); }
      .quick-answer { background: var(--surface-alt); border-left: 4px solid var(--cta); padding: 20px 28px; margin-bottom: 2rem; border-radius: 4px; }
      .quick-answer p { margin: 0; font-size: 1.125rem; line-height: 1.75; }
      .hero-meta { display: flex; flex-wrap: wrap; gap: 16px 24px; margin-bottom: 12px; font-size: 0.9rem; color: var(--concrete); }
      .last-updated { margin: 0; }
      .author-byline { margin: 0; }
      .key-takeaway { background: var(--surface-alt); border: 2px solid var(--border); border-left: 4px solid var(--cta); padding: 20px 28px; margin: 2rem 0; border-radius: 4px; }
      .key-takeaway h3 { font-family: 'Oswald', sans-serif; font-size: 1.1rem; margin: 0 0 12px 0; }
      .key-takeaway p { margin: 0; font-size: 1.0625rem; line-height: 1.7; }
      .related-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin: 2rem 0; padding: 20px 0; border-top: 1px solid var(--border); }
      .related-links h3 { font-family: 'Oswald', sans-serif; font-size: 1.1rem; margin: 0 0 12px 0; }
      .related-links ul { list-style: none; padding: 0; margin: 0; }
      .related-links li { margin-bottom: 8px; }
      .cta-disclaimer { font-size: 0.85rem; color: var(--concrete); margin: 0 0 16px 0; font-style: italic; }
      .glossary-page h2 { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
      .glossary-page h2:first-of-type { margin-top: 0; padding-top: 0; border-top: none; }
      .glossary-page h3 { margin-top: 1.75rem; margin-bottom: 0.75rem; padding: 16px 20px; background: var(--surface-alt); border-left: 4px solid var(--cta); border-radius: 0 4px 4px 0; }
      .glossary-page h3 + p { margin-top: 0; }
      .glossary-page hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
      .glossary-page .prose table { margin: 1.5rem 0; }
      @media (max-width: 768px) {
        .container { padding-left: 20px; padding-right: 20px; }
        .section { padding-top: 56px; padding-bottom: 56px; }
      }
    </style>
  </head>
  <body style="padding:0;">
    <div class="page-content">
    <header>
      <div class="container nav">
        <div class="nav-row nav-row-1">
          <a href="/" class="brand">
            <span class="brand-text">{site.name}</span>
          </a>
          <button class="nav-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
            <span class="nav-toggle-icon-open" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </span>
            <span class="nav-toggle-icon-close" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </span>
          </button>
          <div class="nav-menu" id="nav-menu" data-open="false">
            <ul>
              {site.nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
            </ul>
            <a class="nav-cta btn" href="/explore-contractor-funding-options" style="display: none;">{site.ctaText}</a>
          </div>
        </div>
        <div class="nav-row nav-row-2">
          <a class="btn" href="/explore-contractor-funding-options">{site.ctaText}</a>
        </div>
      </div>
    </header>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const toggle = document.querySelector(".nav-toggle");
        const menu = document.querySelector(".nav-menu");
        if (!toggle || !menu) return;
        toggle.addEventListener("click", () => {
          const isOpen = menu.getAttribute("data-open") === "true";
          menu.setAttribute("data-open", !isOpen);
          toggle.setAttribute("aria-expanded", !isOpen);
        });
        document.addEventListener("click", (e) => {
          if (menu.getAttribute("data-open") === "true" && !menu.contains(e.target) && !toggle.contains(e.target)) {
            menu.setAttribute("data-open", "false");
            toggle.setAttribute("aria-expanded", "false");
          }
        });
      });
    </script>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container footer-grid">
        <p class="footer-brand"><strong>{site.name}</strong> — Educational resource for contractors exploring cash-flow and financing options.</p>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="/contractor-cash-flow-guide">Cash Flow Guide</a>
          <a href="/contractor-working-capital">Working Capital</a>
          <a href="/construction-equipment-financing">Equipment</a>
          <a href="/contractor-line-of-credit">Line of Credit</a>
          <a href="/construction-business-loans">Business Loans</a>
          <a href="/contractor-payroll-funding">Payroll Funding</a>
          <a href="/accounts-receivable-financing-contractors">Accounts Receivable</a>
          <a href="/faq">FAQ</a>
          <a href="/service-areas">Service Areas</a>
          <a href="/all-funding-options">All Options</a>
          <a href="/glossary">Glossary</a>
          <a href="/blog">Blog</a>
        </nav>
        <p class="footer-legal">
          <a href="/about">About</a> · <a href="/contact">Contact</a> · <a href="/editorial-policy">Editorial</a> · <a href="/privacy-policy">Privacy</a> · <a href="/terms">Terms</a> · <a href="/sitemap-index.xml">Sitemap</a>
        </p>
        <p class="footer-disclosure">Informational site. External funding links are disclosed as sponsored.</p>
      </div>
    </footer>
    </div>
  </body>
</html>
