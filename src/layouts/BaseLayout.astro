---
import SeoHead from "../components/SeoHead.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogType?: string;
  imageUrl?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}
const { title, description, canonicalUrl, ogType = "website", imageUrl, articlePublishedTime, articleModifiedTime } = Astro.props;

const baseUrl = new URL("/", site.domain).toString();
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": site.name,
  "url": baseUrl,
  "description": "Educational resource for contractor financing: working capital, equipment financing, business loans, and cash flow solutions for construction businesses.",
  "logo": "https://images.unsplash.com/photo-1766939514629-ca726d1a33ba?w=512&q=80",
  "foundingDate": "2026",
  "areaServed": site.areaServed ?? "United States",
  ...(site.sameAs?.length ? { sameAs: site.sameAs } : {})
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.name,
  "url": baseUrl,
  "description": "Contractor financing guide: working capital, equipment loans, lines of credit, business loans. Funding for construction businesses.",
  "publisher": { "@type": "Organization", "name": site.name, "url": baseUrl },
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${baseUrl.replace(/\/$/, "")}/blog?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  },
  ...(site.sameAs?.length ? { sameAs: site.sameAs } : {})
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href="/logo_transparent_whitegear.png" type="image/png" />
    <link rel="sitemap" type="application/xml" href={new URL("/sitemap.xml", site.domain).toString()} title="Sitemap" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-710G3HQQ32"></script>
    <script>
      {`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-710G3HQQ32');
      `}
    </script>
    <SeoHead
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType={ogType}
  imageUrl={imageUrl}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
  twitterSite={site.twitterSite || undefined}
  twitterCreator={site.twitterCreator || undefined}
/>
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      :root {
        /* Full-width layout: horizontal breathing room + section rhythm */
        --page-pad-x: clamp(1rem, 5vw, 3.75rem);
        --section-pad-y: clamp(3rem, 7vw, 5.5rem);
        --bg: #f2f2f2;
        --surface: #ffffff;
        --surface-alt: #e5e5e5;
        --surface-concrete: #e0e0e0;
        --text: #1a1a1a;
        --text-muted: #4a4a4a;
        --brand: #e85c1a;
        --brand-hover: #c94f16;
        --cta: #e85c1a;
        --cta-hover: #c94f16;
        --border: #c9c9c9;
        --border-light: #d4d4d4;
        --charcoal: #0d0d0d;
        --concrete: #4a4a4a;
        --shadow: 0 1px 2px rgba(0,0,0,.08);
        --shadow-card: 0 2px 8px rgba(0,0,0,.06);
      }
      * { box-sizing: border-box; }
      html {
        overflow-x: hidden;
        width: 100%;
        max-width: 100%;
        background: var(--bg);
      }
      body {
        overflow-x: hidden;
        margin: 0;
        width: 100%;
        max-width: 100%;
        min-height: 100vh;
        font-family: 'Source Sans 3', system-ui, sans-serif;
        font-size: 18px;
        line-height: 1.75;
        color: var(--text);
        background: var(--bg);
        text-align: center;
      }
      img { max-width: 100%; height: auto; }
      a { color: inherit; text-decoration: none; }
      h1 { font-family: 'Oswald', sans-serif; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 20px; font-weight: 700; color: var(--charcoal); text-align: center; }
      h2 { font-family: 'Oswald', sans-serif; font-size: clamp(1.8rem, 3vw, 3rem); line-height: 1.1; margin-bottom: 18px; font-weight: 700; color: var(--charcoal); text-align: center; }
      h3 { font-family: 'Oswald', sans-serif; font-size: 1.3rem; margin-bottom: 14px; font-weight: 700; color: var(--charcoal); text-align: center; }
      p { margin-bottom: 20px; }
      p:last-child { margin-bottom: 0; }
      /*
        Content fills the centered body (max-width above). Inner padding only — no second max-width
        column, so header/footer/main stay aligned.
      */
      .container {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        margin-inline: 0;
        padding-left: calc(var(--page-pad-x) + env(safe-area-inset-left, 0px));
        padding-right: calc(var(--page-pad-x) + env(safe-area-inset-right, 0px));
        box-sizing: border-box;
      }
      header .container,
      footer .container {
        overflow: visible;
      }
      /*
        Readable column for article content. Flex lets MDX blocks (and FAQ fragments) align consistently;
        full-width components opt out below.
      */
      article.container.prose {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        width: 100%;
        margin-inline: 0;
      }
      article.container.prose > * {
        width: 100%;
        max-width: 72ch;
        margin-left: auto;
        margin-right: auto;
        box-sizing: border-box;
        text-align: center;
      }
      article.container.prose > ul,
      article.container.prose > ol {
        text-align: left;
        list-style-position: outside;
        padding-left: 1.5rem;
        padding-right: 0;
      }
      article.container.prose > .cta,
      article.container.prose > .quick-answer,
      article.container.prose > .key-takeaway,
      article.container.prose > .related-links,
      article.container.prose > .situations-table-wrapper,
      article.container.prose > table,
      article.container.prose > .mid-page-cta,
      article.container.prose > section[aria-label="Request a call back"] {
        max-width: 100%;
        margin-left: 0;
        margin-right: 0;
      }
      .glossary-page.prose > * {
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
      }
      .glossary-page.prose table { margin-left: auto; margin-right: auto; }
      .section {
        padding-top: var(--section-pad-y);
        padding-bottom: var(--section-pad-y);
      }
      .page-content {
        position: relative;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: hidden;
        box-sizing: border-box;
      }
      .btn {
        display: inline-block;
        width: auto;
        background: var(--cta);
        color: #fff !important;
        padding: 12px 24px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.9rem;
        font-family: 'Oswald', sans-serif;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: background .2s;
        border: none;
        cursor: pointer;
      }
      .btn:hover { background: var(--cta-hover); }
      .btn-secondary {
        display: inline-block;
        width: auto;
        background: var(--surface);
        color: var(--charcoal) !important;
        padding: 12px 24px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.9rem;
        font-family: 'Oswald', sans-serif;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border: 2px solid var(--cta);
        transition: background .2s, color .2s, border-color .2s;
        cursor: pointer;
        margin-top: 0.5rem;
      }
      .btn-secondary:hover {
        background: var(--surface-alt);
        color: var(--cta) !important;
        border-color: var(--cta-hover);
      }
      .cta .cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        justify-content: center;
        margin-top: 4px;
      }
      .cta-phone {
        margin: 1rem auto 0 auto;
        font-size: 0.95rem;
        color: var(--concrete);
        max-width: 75ch;
      }
      .cta-phone a {
        color: var(--charcoal);
        font-weight: 700;
        background: transparent !important;
        border: none !important;
        padding: 0 !important;
        text-decoration: underline;
      }
      .cta-phone a:hover {
        color: var(--cta) !important;
      }
      .btn-link {
        display: inline-block;
        width: auto;
        background: var(--surface);
        color: var(--charcoal) !important;
        padding: 8px 14px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.9rem;
        border: 2px solid var(--border);
        transition: background .2s, border-color .2s;
      }
      .btn-link:hover { background: var(--surface-alt); border-color: var(--cta); color: var(--cta) !important; }
      .hero { padding: 28px 0 24px; }
      .hero h1 { font-family: 'Oswald', sans-serif; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 20px; font-weight: 600; }
      .hero p { font-size: 1.125rem; line-height: 1.75; color: var(--text-muted); max-width: 72ch; margin-left: auto; margin-right: auto; margin-bottom: 20px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; margin: 20px 0; justify-items: center; }
      .card {
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 6px;
        padding: 24px;
        box-shadow: var(--shadow-card);
        transition: border-color .2s, box-shadow .2s;
        overflow: hidden;
        text-align: center;
        width: 100%;
        max-width: 420px;
      }
      .card:hover { border-color: var(--cta); box-shadow: 0 4px 12px rgba(0,0,0,.08); }
      main {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: hidden;
        padding-bottom: clamp(2.5rem, 5vw, 4rem);
        text-align: center;
      }
      article, .prose { max-width: 100%; overflow-wrap: break-word; word-wrap: break-word; }
      .prose h2 { font-family: 'Oswald', sans-serif; font-size: clamp(1.8rem, 3vw, 3rem); line-height: 1.1; margin-top: 2.5rem; margin-bottom: 18px; font-weight: 700; letter-spacing: -0.01em; color: var(--charcoal); text-align: center; }
      .prose h2:first-child { margin-top: 0; }
      .prose h3 { font-family: 'Oswald', sans-serif; font-size: 1.3rem; margin-top: 2rem; margin-bottom: 14px; font-weight: 700; color: var(--charcoal); text-align: center; }
      .prose ul, .prose ol { padding-left: 1.25rem; text-align: left; margin-left: auto; margin-right: auto; max-width: min(72ch, 100%); }
      .prose li { margin-bottom: 0.5rem; }
      .prose p { margin-bottom: 20px; line-height: 1.75; color: var(--text); text-align: center; }
      .prose a {
        display: inline;
        background: var(--surface-alt);
        color: var(--charcoal) !important;
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 600;
        border: 1px solid var(--border);
        transition: background .2s, border-color .2s;
      }
      .prose a:hover { background: var(--surface); border-color: var(--cta); color: var(--cta) !important; }
      .prose ul a, .prose ol a { display: inline-block; margin: 4px 8px 4px 0; }
      .prose table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
      .prose th, .prose td { padding: 12px 14px; text-align: center; border: 1px solid var(--border); }
      .prose th { background: var(--surface-alt); font-weight: 600; }
      .prose tr:nth-child(even) { background: var(--surface); }
      .situations-table-wrapper { overflow-x: auto; margin: 1.25rem 0; -webkit-overflow-scrolling: touch; }
      .situations-table-wrapper table { min-width: 320px; }
      @media (max-width: 640px) {
        .prose th, .prose td { padding: 10px 12px; font-size: 0.9rem; }
      }
      .cta {
        background: var(--surface);
        border: 2px solid var(--cta);
        border-radius: 4px;
        padding: 24px;
        margin-top: 28px;
        text-align: center;
      }
      .cta h2 { font-family: 'Oswald', sans-serif; margin-top: 0 !important; font-size: 1.3rem; letter-spacing: 0.03em; text-transform: uppercase; color: var(--charcoal); }
      .cta-reassurance { font-size: 0.95rem; color: var(--concrete); margin: 0 auto 16px auto; font-style: italic; max-width: 75ch; }
      footer { padding: 56px 0 64px; background: var(--charcoal); color: #9ca3af; border-top: 4px solid var(--cta); text-align: center; }
      .footer-grid { display: grid; gap: 32px; justify-items: center; }
      .footer-brand { font-size: 1rem; margin: 0; color: #e5e7eb; line-height: 1.5; }
      .footer-nav { display: flex; flex-wrap: wrap; flex: 1 1 auto; justify-content: center; gap: 10px 16px; }
      .footer-nav a { color: #94a3b8; padding: 4px 8px; border-radius: 4px; white-space: nowrap; }
      .footer-nav a:hover { color: var(--cta); }
      .footer-legal { font-size: 0.9rem; margin: 0; opacity: .9; }
      .footer-legal a { color: #94a3b8; }
      .footer-legal a:hover { color: var(--cta); }
      .footer-disclosure { font-size: 0.8rem; margin: 0; opacity: .7; }
      .small { font-size: 0.85rem; color: var(--text-muted); }
      .hero-page { position: relative; overflow: hidden; border-left: 4px solid var(--cta); }
      .hero-page-bg { position: absolute; inset: 0; background: linear-gradient(135deg, var(--surface-alt) 0%, var(--surface) 100%); opacity: .95; }
      .hero-page-content { position: relative; z-index: 1; padding-top: 48px; padding-bottom: 48px; }
      .hero-page-content h1 { color: var(--charcoal); font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 20px; max-width: 72ch; margin-left: auto; margin-right: auto; }
      .hero-page-content p { color: var(--concrete); font-size: 1.125rem; line-height: 1.75; margin-bottom: 20px; max-width: 72ch; margin-left: auto; margin-right: auto; }
      .card-img { padding: 0; display: block; }
      .card-img .card-image { aspect-ratio: 16/9; overflow: hidden; border-radius: 8px 8px 0 0; }
      .card-img .card-image img { width: 100%; height: 100%; object-fit: cover; transition: opacity .2s; }
      .card-img:hover .card-image img { opacity: .9; }
      .card-img .card-body { padding: 14px 16px; }
      .card-img .card-body strong { display: block; margin-bottom: 4px; font-size: 0.95rem; font-weight: 600; }
      .card-img .card-body p { margin: 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; }
      .breadcrumb { padding: 12px 0; font-size: 0.9rem; color: var(--text-muted); background: var(--surface-alt); text-align: center; }
      .breadcrumb a { color: var(--text-muted); }
      .breadcrumb a:hover { color: var(--text); }
      .breadcrumb span:last-child { color: var(--text); }
      .quick-answer { background: var(--surface-alt); border-left: 4px solid var(--cta); padding: 20px 28px; margin-bottom: 2rem; border-radius: 4px; text-align: center; }
      .quick-answer p { margin: 0; font-size: 1.125rem; line-height: 1.75; text-align: center; }
      .hero-meta { display: flex; flex-wrap: wrap; gap: 16px 24px; margin-bottom: 12px; font-size: 0.9rem; color: var(--concrete); justify-content: center; }
      .last-updated { margin: 0; }
      .author-byline { margin: 0; }
      .key-takeaway { background: var(--surface-alt); border: 2px solid var(--border); border-left: 4px solid var(--cta); padding: 20px 28px; margin: 2rem 0; border-radius: 4px; text-align: center; }
      .key-takeaway h3 { font-family: 'Oswald', sans-serif; font-size: 1.1rem; margin: 0 0 12px 0; text-align: center; }
      .key-takeaway p { margin: 0; font-size: 1.0625rem; line-height: 1.7; text-align: center; }
      .related-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin: 2rem 0; padding: 20px 0; border-top: 1px solid var(--border); text-align: center; justify-items: center; }
      .related-links h3 { font-family: 'Oswald', sans-serif; font-size: 1.1rem; margin: 0 0 12px 0; text-align: center; }
      .related-links ul {
        text-align: left;
        margin-left: auto;
        margin-right: auto;
        max-width: 56ch;
        list-style: none;
        padding: 0;
      }
      .related-links li { margin-bottom: 8px; }
      .cta-disclaimer { font-size: 0.85rem; color: var(--concrete); margin: 0 0 16px 0; font-style: italic; }
      .glossary-page h2 { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
      .glossary-page h2:first-of-type { margin-top: 0; padding-top: 0; border-top: none; }
      .glossary-page h3 { margin-top: 1.75rem; margin-bottom: 0.75rem; padding: 16px 20px; background: var(--surface-alt); border-left: 4px solid var(--cta); border-radius: 0 4px 4px 0; }
      .glossary-page h3 + p { margin-top: 0; }
      .glossary-page hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
      .glossary-page .prose table { margin: 1.5rem 0; }
      @media (max-width: 768px) {
        :root {
          --page-pad-x: clamp(1rem, 4.5vw, 1.5rem);
          --section-pad-y: clamp(2.5rem, 8vw, 4rem);
        }
        .footer-grid { text-align: center; }
        .footer-brand { margin-inline: auto; max-width: 52ch; }
      }
    </style>
    <style is:global>
      /* Header / nav — global so dropdown + breakpoints work on every route (not tied to one Astro scope hash). */
      .site-header {
        background: var(--charcoal);
        border-bottom: 4px solid var(--cta);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
        position: sticky;
        top: 0;
        z-index: 200;
        overflow: visible;
        text-align: left;
      }
      .site-header .container.nav,
      .site-header .nav-row-1 {
        overflow: visible;
      }
      .site-header .nav {
        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 0;
        position: relative;
        text-align: left;
      }
      .site-header .nav-row {
        display: flex;
        align-items: center;
        gap: 16px 24px;
        padding: 14px 0;
        min-width: 0;
      }
      .site-header .nav-row-1 {
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        padding-top: 18px;
        position: relative;
      }
      .site-header .nav-row-1 .brand {
        flex: 0 1 auto;
        min-width: 0;
        text-align: left;
      }
      .site-header .nav-row-1 .nav-toggle {
        flex: 0 0 auto;
        margin-left: auto;
      }
      .site-header .nav-row-2 {
        justify-content: center;
        border-top: 1px solid rgba(255, 255, 255, 0.15);
        padding-bottom: 18px;
      }
      .site-header .nav .brand {
        flex-shrink: 0;
      }
      .site-header .nav-links-mobile,
      .site-header .nav-primary-inline,
      .site-header .nav-more-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .site-header .nav-links-mobile {
        display: none !important;
      }
      .site-header .nav-links-desktop {
        display: flex;
        flex: 1 1 auto;
        min-width: 0;
        align-items: center;
        justify-content: flex-end;
        gap: 4px 12px;
        flex-wrap: wrap;
      }
      .site-header .nav-primary-inline {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px 14px;
        flex-wrap: wrap;
        min-width: 0;
      }
      .site-header .nav-more-wrap {
        position: relative;
        flex-shrink: 0;
        z-index: 300;
      }
      .site-header .nav-more-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 4px;
        cursor: pointer;
        color: #e5e7eb;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 6px 12px;
        font-family: inherit;
        line-height: 1.2;
      }
      .site-header .nav-more-btn:hover {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.4);
        background: rgba(255, 255, 255, 0.1);
      }
      .site-header .nav-more-btn[aria-expanded="true"] {
        color: #fff;
        border-color: var(--cta);
        background: rgba(232, 92, 26, 0.15);
      }
      .site-header .nav-more-chevron {
        font-size: 0.7em;
        opacity: 0.95;
      }
      .site-header .nav-more-panel {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        left: auto;
        min-width: 240px;
        max-width: min(340px, 92vw);
        max-height: min(70vh, 440px);
        overflow-y: auto;
        overflow-x: hidden;
        padding: 8px 0;
        background: #1a2332;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.55);
        z-index: 500;
      }
      .site-header .nav-more-panel[hidden] {
        display: none !important;
      }
      .site-header .nav-more-panel:not([hidden]) {
        display: block !important;
      }
      .site-header .nav-more-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .site-header .nav-more-list li {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .site-header .nav-more-list li:last-child {
        border-bottom: none;
      }
      .site-header .nav-more-list a {
        display: block;
        padding: 10px 18px;
        font-size: 0.9rem;
        white-space: nowrap;
        color: #e5e7eb !important;
      }
      .site-header .nav-more-list a:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff !important;
      }
      .site-header .nav-desktop-phone {
        flex-shrink: 0;
        font-size: 0.85rem;
        white-space: nowrap;
      }
      .site-header .nav a {
        color: #94a3b8;
        font-weight: 500;
        font-size: 0.85rem;
        white-space: nowrap;
        transition: color 0.2s;
      }
      .site-header .nav a:hover {
        color: #fff;
      }
      .site-header .brand {
        display: inline-flex;
        align-items: center;
        justify-content: flex-start;
        gap: 12px;
        font-family: "Oswald", sans-serif;
        font-weight: 700;
        font-size: clamp(0.95rem, 2.2vw, 1.3rem);
        color: #fff;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        text-align: left;
        line-height: 1.15;
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .site-header .brand-text {
        display: block;
        text-align: left;
      }
      .site-header .nav-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        color: #fff;
      }
      .site-header .nav-toggle svg {
        width: 28px;
        height: 28px;
      }
      .site-header .nav-toggle[aria-expanded="true"] .nav-toggle-icon-open {
        display: none;
      }
      .site-header .nav-toggle[aria-expanded="true"] .nav-toggle-icon-close {
        display: block;
      }
      .site-header .nav-toggle .nav-toggle-icon-close {
        display: none;
      }
      @media (max-width: 1023px) {
        .site-header .nav-row-2 {
          display: none !important;
        }
        .site-header .nav-toggle {
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .site-header .nav-row-1 .nav-menu {
          flex-basis: 100%;
          width: 100%;
          order: 3;
          margin: 0;
          padding: 0;
          background: var(--charcoal);
          border-bottom: 4px solid var(--cta);
          max-height: 0;
          overflow: hidden;
          transition: max-height 0.35s ease;
          box-sizing: border-box;
        }
        .site-header .nav-menu[data-open="true"] {
          max-height: 80vh;
          overflow-y: auto;
        }
        .site-header .nav-links-desktop {
          display: none !important;
        }
        .site-header .nav-links-mobile {
          display: flex !important;
          flex-direction: column;
          align-items: stretch;
          justify-content: flex-start;
          gap: 0;
          padding: 8px 0 16px;
          flex: 1 1 auto;
          min-width: 0;
        }
        .site-header .nav-links-mobile li {
          border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .site-header .nav-links-mobile li:last-child {
          border-bottom: none;
        }
        .site-header .nav-links-mobile a {
          display: block;
          padding: 14px 16px;
          font-size: 1rem;
          white-space: normal;
        }
        .site-header .nav-links-mobile a.header-phone {
          margin: 8px 12px 16px;
          text-align: center;
          border-radius: 4px;
        }
        .site-header .nav-menu .nav-cta {
          display: block !important;
          padding: 16px 20px;
          margin: 16px 12px;
          text-align: center;
          background: var(--cta);
          color: #fff !important;
          border-radius: 4px;
          font-weight: 700;
        }
      }
      @media (min-width: 1024px) {
        .site-header .nav-row-1 {
          flex-wrap: nowrap;
          justify-content: flex-start;
          gap: 20px;
        }
        .site-header .nav-row-1 .nav-toggle {
          display: none !important;
        }
        .site-header .nav-row-1 .brand {
          margin-left: 0;
          flex: 0 1 auto;
        }
        .site-header .nav-row-1 .nav-menu {
          display: flex !important;
          flex: 1 1 auto;
          min-width: 0;
          order: 0;
          max-height: none !important;
          overflow: visible !important;
          background: transparent;
          border-bottom: none;
          margin: 0;
          padding: 0;
        }
        .site-header .nav-menu .nav-cta {
          display: none !important;
        }
        .site-header .nav-links-desktop {
          display: flex !important;
        }
        .site-header .nav-primary-inline {
          justify-content: flex-end;
          flex-wrap: wrap;
        }
      }
    </style>
    <!--
      Global styles: Astro scopes layout CSS to this file only, so rules like `.card` / `.prose p`
      do not match slotted content from pages. `text-align` must be set globally for main content.
    -->
    <style is:global>
      main {
        text-align: center;
        overflow-x: hidden;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
      }
      main article.prose :is(p, h2, h3, h4) {
        text-align: center;
      }
      main article.prose :is(ul, ol) {
        text-align: left;
        margin-left: auto;
        margin-right: auto;
      }
      main article.prose li {
        text-align: left;
      }
      main article.prose table :is(th, td) {
        text-align: center;
      }
      main :is(.card, a.card, .problem-card, a.problem-card, .card-funding, a.card-funding, .card-latest, a.card-latest, .blog-card, article.blog-card, .solution-card, a.solution-card) {
        text-align: center;
      }
      main :is(.problem-card, a.problem-card, .card-funding, a.card-funding, .card-latest, a.card-latest) :is(h2, h3, p, span) {
        text-align: center;
      }
      main .blog-card :is(h2, p, time, a) {
        text-align: center;
      }
      main article.blog-card :is(h2, p, time, a.read-more) {
        width: 100%;
        text-align: center;
        align-self: stretch;
      }
      main .card-img .card-body,
      main .card-img .card-body :is(strong, p) {
        text-align: center;
      }
      main .mid-page-cta,
      main .mid-page-cta :is(h2, p) {
        text-align: center;
      }
      main .contact-lead-form {
        text-align: center;
      }
      main .contact-lead-form .contact-field span {
        text-align: center;
      }
      main :is(.solutions-grid, .blog-grid) {
        justify-items: center;
      }
      /* Homepage / landing blocks (not inside article.prose) */
      main .container-narrow {
        margin-left: auto;
        margin-right: auto;
        width: 100%;
      }
      main .definition-block,
      main .definition-block :is(h2, p) {
        text-align: center;
      }
      main .definition-block p a {
        display: inline;
        text-align: center;
      }
      /* Card text centering — avoid width:100% here (breaks grid / causes overlap with scoped page CSS) */
      main a.problem-card :is(h3, p, span.problem-card-link),
      main a.card-funding :is(h3, p, span.card-cta),
      main a.card-latest :is(h3, p, span.card-cta, p.card-date) {
        text-align: center;
      }
      main a.solution-card {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        text-align: center;
        gap: 10px 12px;
        max-width: 420px;
        width: 100%;
        box-sizing: border-box;
      }
      main a.solution-card :is(.solution-problem, .solution-arrow, .solution-option) {
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="page-content">
    <header class="site-header">
      <div class="container nav">
        <div class="nav-row nav-row-1">
          <a href="/" class="brand">
            <span class="brand-text">{site.name}</span>
          </a>
          <button class="nav-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
            <span class="nav-toggle-icon-open" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </span>
            <span class="nav-toggle-icon-close" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </span>
          </button>
          <div class="nav-menu" id="nav-menu" data-open="false">
            <ul class="nav-links-mobile">
              {site.nav.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
              <li>
                <a href={site.phoneHref} class="header-phone">
                  📞 {site.phone}
                </a>
              </li>
            </ul>
            <div class="nav-links-desktop" aria-label="Main navigation">
              <ul class="nav-primary-inline">
                {site.navPrimary.map((item) => (
                  <li>
                    <a href={item.href}>{item.label}</a>
                  </li>
                ))}
              </ul>
              <div class="nav-more-wrap">
                <button
                  type="button"
                  class="nav-more-btn"
                  id="nav-more-btn"
                  aria-expanded="false"
                  aria-haspopup="menu"
                  aria-controls="nav-more-panel"
                >
                  More <span class="nav-more-chevron" aria-hidden="true">▼</span>
                </button>
                <div id="nav-more-panel" class="nav-more-panel" hidden role="menu" aria-labelledby="nav-more-btn">
                  <ul class="nav-more-list">
                    {site.navMore.map((item) => (
                      <li role="none">
                        <a href={item.href} role="menuitem">{item.label}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
              <a href={site.phoneHref} class="header-phone nav-desktop-phone">
                📞 {site.phone}
              </a>
            </div>
            <a class="nav-cta btn" href="/explore-contractor-funding-options" style="display: none;">{site.ctaText}</a>
          </div>
        </div>
        <div class="nav-row nav-row-2">
          <a class="btn" href="/explore-contractor-funding-options">{site.ctaText}</a>
        </div>
      </div>
    </header>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const toggle = document.querySelector(".nav-toggle");
        const menu = document.querySelector(".nav-menu");
        if (!toggle || !menu) return;
        toggle.addEventListener("click", () => {
          const isOpen = menu.getAttribute("data-open") === "true";
          menu.setAttribute("data-open", !isOpen);
          toggle.setAttribute("aria-expanded", !isOpen);
        });
        document.addEventListener("click", (e) => {
          if (menu.getAttribute("data-open") === "true" && !menu.contains(e.target) && !toggle.contains(e.target)) {
            menu.setAttribute("data-open", "false");
            toggle.setAttribute("aria-expanded", "false");
          }
        });
        const moreBtn = document.getElementById("nav-more-btn");
        const morePanel = document.getElementById("nav-more-panel");
        if (moreBtn && morePanel) {
          moreBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            const open = moreBtn.getAttribute("aria-expanded") === "true";
            moreBtn.setAttribute("aria-expanded", String(!open));
            morePanel.hidden = open;
          });
          morePanel.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
              morePanel.hidden = true;
              moreBtn.setAttribute("aria-expanded", "false");
            });
          });
          document.addEventListener("click", (e) => {
            if (morePanel.hidden) return;
            const t = e.target;
            if (t instanceof Node && (moreBtn.contains(t) || morePanel.contains(t))) return;
            morePanel.hidden = true;
            moreBtn.setAttribute("aria-expanded", "false");
          });
          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !morePanel.hidden) {
              morePanel.hidden = true;
              moreBtn.setAttribute("aria-expanded", "false");
            }
          });
        }
      });
    </script>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container footer-grid">
        <p class="footer-brand"><strong>{site.name}</strong> — Educational resource for contractors exploring cash-flow and financing options.</p>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="/contractor-cash-flow-guide">Cash Flow Guide</a>
          <a href="/contractor-working-capital">Working Capital</a>
          <a href="/construction-equipment-financing">Equipment</a>
          <a href="/contractor-line-of-credit">Line of Credit</a>
          <a href="/construction-business-loans">Business Loans</a>
          <a href="/contractor-payroll-funding">Payroll Funding</a>
          <a href="/accounts-receivable-financing-contractors">Accounts Receivable</a>
          <a href="/faq">FAQ</a>
          <a href="/service-areas">Service Areas</a>
          <a href="/all-funding-options">All Options</a>
          <a href="/glossary">Glossary</a>
          <a href="/blog">Blog</a>
        </nav>
        <p class="footer-legal">
          <a href="/about">About</a> · <a href="/contact">Contact</a> · <a href="/editorial-policy">Editorial</a> · <a href="/privacy-policy">Privacy</a> · <a href="/terms">Terms</a> · <a href="/sitemap.xml">Sitemap</a>
        </p>
        <p class="footer-disclosure">Informational site. External funding links are disclosed as sponsored.</p>
      </div>
    </footer>
    </div>
  </body>
</html>
