---
import SeoHead from "../components/SeoHead.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogType?: string;
}
const { title, description, canonicalUrl, ogType = "website" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead title={title} description={description} canonicalUrl={canonicalUrl} ogType={ogType} />
    <style>
      :root { --bg:#f8f6f1; --text:#152132; --muted:#5d6878; --brand:#1e3a5f; --accent:#c89b3c; --card:#ffffff; }
      * { box-sizing:border-box; }
      body { margin:0; font-family: system-ui, Arial, sans-serif; background:var(--bg); color:var(--text); line-height:1.6; }
      a { color:var(--brand); text-decoration:none; }
      .container { width:min(1080px, calc(100% - 32px)); margin:0 auto; }
      header { border-bottom:1px solid #e6dfd0; background:#fffdf8; position:sticky; top:0; z-index:10; }
      .nav { display:flex; justify-content:space-between; align-items:center; gap:16px; padding:16px 0; }
      .nav ul { display:flex; gap:16px; list-style:none; padding:0; margin:0; flex-wrap:wrap; }
      .brand { font-weight:800; color:var(--brand); }
      .btn { display:inline-block; background:var(--brand); color:#fff; padding:12px 18px; border-radius:10px; font-weight:700; }
      .hero { padding:72px 0 32px; }
      .hero h1 { font-size:clamp(2rem, 5vw, 3.5rem); line-height:1.05; margin:0 0 16px; }
      .hero p { font-size:1.1rem; color:var(--muted); max-width:760px; }
      .grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:18px; margin:24px 0 40px; }
      .card { background:var(--card); border:1px solid #ece7db; border-radius:16px; padding:20px; }
      main { padding-bottom:60px; }
      article, .prose { max-width:820px; }
      h2 { margin-top:40px; }
      .cta { background:#fff; border:1px solid #ece7db; border-radius:18px; padding:24px; margin-top:40px; }
      footer { padding:36px 0 56px; border-top:1px solid #e6dfd0; color:var(--muted); }
      .small { font-size:.95rem; color:var(--muted); }
    </style>
  </head>
  <body>
    <header>
      <div class="container nav">
        <a href="/" class="brand">{site.name}</a>
        <ul>
          {site.nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        </ul>
        <a class="btn" href={site.ctaUrl} rel="sponsored noopener noreferrer" target="_blank">{site.ctaText}</a>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <p><strong>{site.name}</strong> helps contractors understand working capital, equipment financing, and construction business funding options.</p>
        <p class="small">Informational site. External funding links should be reviewed for compliance and disclosures before launch.</p>
      </div>
    </footer>
  </body>
</html>
